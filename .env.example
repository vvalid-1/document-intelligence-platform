# ─── Database ────────────────────────────────────────────────────────────────
DB_USER=docplat
DB_PASSWORD=change_me_in_production
DB_NAME=docplat
DB_HOST=postgres
DB_PORT=5432

# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_THREAD=4
OLLAMA_NUM_PREDICT=1024

# ─── ChromaDB ────────────────────────────────────────────────────────────────
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# ─── JWT Authentication ───────────────────────────────────────────────────────
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Must be at least 32 characters. The server refuses to start with a weak value.
JWT_SECRET_KEY=CHANGE_ME_run_python3_-c_import_secrets_print_secrets.token_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# ─── Agent Settings ───────────────────────────────────────────────────────────
AGENT_TIMEOUT_SECONDS=300
MAX_CHAT_MESSAGE_CHARS=8000
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ─── Security ─────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80
# In production: CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
